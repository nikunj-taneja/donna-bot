#!/usr/bin/env python3
"""
Host-side Unix socket server for Donna gateway control.
Runs as root. Accepts only: reload | restart | status
Bind-mount the client (/usr/local/bin/donna-ctl) and socket
(/run/donna-ctl.sock) into containers so Donna can call it.
"""
import os
import socket
import subprocess
import sys

SOCKET_PATH = "/run/donna-ctl.sock"
ALLOWED = frozenset({"reload", "restart", "status"})
SERVICE = "donna"


def handle(conn: socket.socket) -> None:
    try:
        cmd = conn.recv(64).decode().strip().lower()
        if cmd not in ALLOWED:
            conn.sendall(f"error: '{cmd}' not allowed. Use: {', '.join(sorted(ALLOWED))}\n".encode())
            return
        result = subprocess.run(
            ["systemctl", cmd, SERVICE],
            capture_output=True, text=True, timeout=15,
        )
        output = (result.stdout + result.stderr).strip()
        conn.sendall((output + "\n").encode())
    except Exception as exc:
        conn.sendall(f"error: {exc}\n".encode())
    finally:
        conn.close()


def main() -> None:
    if os.geteuid() != 0:
        sys.exit("donna-ctl-server must run as root")

    if os.path.exists(SOCKET_PATH):
        os.unlink(SOCKET_PATH)

    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(SOCKET_PATH)
    os.chmod(SOCKET_PATH, 0o666)  # world-accessible; security is command allowlist
    srv.listen(5)

    print(f"donna-ctl-server listening on {SOCKET_PATH}", flush=True)
    while True:
        conn, _ = srv.accept()
        handle(conn)


if __name__ == "__main__":
    main()
