# Copy to /opt/donna/.env on the VPS and fill in values.
# This file is NOT committed with real values.

# Google AI Studio API key — https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Telegram bot token — from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=...

# Random token for gateway WebSocket auth — generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_AUTH_TOKEN=...

# Google OAuth 2.0 — copy google_oauth_client_secret.json to VPS, then point here
# Client credentials file from Google Cloud Console (OAuth 2.0 → Desktop app)
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/opt/donna/google_oauth_client_secret.json
# Populated automatically after first auth flow; stores refresh token
GOOGLE_OAUTH_TOKEN_FILE=/opt/donna/google_oauth_token.json
