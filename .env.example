# Copy to /opt/donna-bot/.env on the VPS and fill in values.
# This file is NOT committed with real values.

# Google AI Studio API key — https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Telegram bot token — from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=...

# Random token for gateway WebSocket auth — generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_AUTH_TOKEN=...

# Google Workspace CLI (gws) — auth is managed by gws itself, not env vars.
# After deploy, run once as the donna user:
#   sudo -u donna GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file gws auth login
# Tokens are stored in /opt/donna-bot/.config/gws/ and refreshed automatically.
